---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const seasonal = allArticles.filter(a => a.data.category === 'Seasonal');
seasonal.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const upcoming = [
  { emoji: '☀️', name: 'Summer Weekend Bucket List', season: 'June' },
  { emoji: '🎆', name: '4th of July Weekend Guide', season: 'July' },
  { emoji: '🍂', name: 'Fall Weekend Getaways', season: 'September' },
  { emoji: '🎃', name: 'Halloween Weekend Fun', season: 'October' },
];
---
<BaseLayout title="Seasonal" description="Timely ideas for holidays, seasons, and long weekends — so you don't waste another three-day weekend.">
  <Header slot="header" />

  <div class="container" style="padding-top:3rem;padding-bottom:3rem;">
    <div class="page-header">
      <h1 class="page-header__title">Seasonal</h1>
      <p class="page-header__desc">Timely ideas for holidays, seasons, and long weekends — so you don't waste another three-day weekend on the couch.</p>
    </div>

    {seasonal.length > 0 && (
      <div class="card-grid card-grid--3" style="margin-bottom:2.5rem;">
        {seasonal.map(article => (
          <a href={`/guides/${article.slug}`} class="guide-card">
            <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#CC5500,#ff8c42)'};`}>
              <span style="filter:drop-shadow(0 2px 8px rgba(0,0,0,0.2));font-size:3rem;">{article.data.thumbnail || '📅'}</span>
            </div>
            <div class="guide-card__body">
              <span class="guide-card__cat">Seasonal</span>
              <h2 class="guide-card__title">{article.data.title}</h2>
              {article.data.description && (
                <p class="guide-card__desc">{article.data.description}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- Upcoming -->
    <h3 style="font-size:1.1rem;font-weight:700;color:#2c2c2c;margin:0 0 1rem;">Coming up next</h3>
    <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));">
      {upcoming.map(item => (
        <div class="coming-soon-card">
          <span class="coming-soon-card__emoji">{item.emoji}</span>
          <div>
            <span class="coming-soon-card__name">{item.name}</span>
            <span class="coming-soon-card__status">{item.season}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
