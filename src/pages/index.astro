---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = [...allArticles].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);
const seasonal = allArticles.filter(a => a.data.category === 'Seasonal');
const latestSeasonal = seasonal.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())[0];

// Short display titles for cards (avoid overwhelming long titles)
const shortTitles: Record<string, string> = {
  'the-perfect-weekend-in-leavenworth-wa': 'Perfect Leavenworth Weekend',
  'memorial-day-weekend-ideas': 'Memorial Day: 15 Ideas',
  'how-to-host-a-friendsgiving-thats-actually-fun': 'Host a Real Friendsgiving',
  'neighborhood-block-party-playbook': 'Block Party Playbook',
  'the-lazy-sunday-brunch-kit': 'Lazy Sunday Brunch',
  'the-stargazing-night-guide': 'Stargazing Night Guide',
  'the-no-stress-family-hiking-guide': 'No-Stress Family Hikes',
  '25-at-home-date-night-ideas': '25 Date Night Ideas',
  '12-best-board-games-for-couples': 'Board Games for Couples',
  'weekend-camping-for-couples-who-dont-camp': 'Camping for Non-Campers',
  'rock-climbing-for-beginners': 'Rock Climbing 101',
  'trail-running-for-total-beginners': 'Trail Running 101',
  'the-weekend-pickleball-starter-guide': 'Pickleball Starter Guide',
  'weekend-activities-for-kids-that-dont-involve-screens': 'Screen-Free Kid Activities',
  'the-sunday-family-cook-off': 'Family Cook-Off',
  'the-ultimate-game-night-guide': 'Ultimate Game Night',
  'the-unplugged-weekend-challenge': 'Unplugged Weekend',
  'how-to-plan-the-perfect-backyard-night': 'Perfect Backyard Night',
};
---
<BaseLayout title="Weekend Destination Guides & Activity Ideas" description="Weekend destination guides and outdoor activity ideas for the Pacific Northwest — written from experience by a family that actually does this stuff.">
  <Header slot="header" />

  <!-- HERO — compact, scannable in 3 seconds -->
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__title">Your weekends deserve<br/>better than the couch.</h1>
      <p class="hero__subtitle">PNW destination guides & weekend ideas — from a family that actually does this stuff.</p>
    </div>
  </section>

  <!-- CATEGORY CHIP BAR — Airbnb-style horizontal scroll, visual shortcut -->
  <nav class="chip-bar" aria-label="Browse by category">
    <div class="chip-bar__track">
      <a href="/guides/the-perfect-weekend-in-leavenworth-wa" class="chip chip--featured">
        <span class="chip__icon">🏔️</span>
        <span class="chip__label">Leavenworth</span>
      </a>
      <a href="/guides/outdoor" class="chip">
        <span class="chip__icon">🏕️</span>
        <span class="chip__label">Outdoor</span>
      </a>
      <a href="/guides/couples" class="chip">
        <span class="chip__icon">❤️</span>
        <span class="chip__label">Couples</span>
      </a>
      <a href="/guides/family" class="chip">
        <span class="chip__icon">👨‍👩‍👧‍👦</span>
        <span class="chip__label">Family</span>
      </a>
      <a href="/guides/friends" class="chip">
        <span class="chip__icon">🎉</span>
        <span class="chip__label">Friends</span>
      </a>
      {latestSeasonal && (
        <a href={`/guides/${latestSeasonal.slug}`} class="chip chip--seasonal">
          <span class="chip__icon">🇺🇸</span>
          <span class="chip__label">Memorial Day</span>
        </a>
      )}
      <a href="/guides" class="chip chip--all">
        <span class="chip__icon">→</span>
        <span class="chip__label">All Guides</span>
      </a>
    </div>
  </nav>

  <!-- FEATURED — Leavenworth spotlight, the hero card -->
  <section class="section" style="padding-top:0.75rem;">
    <div class="container">
      <a href="/guides/the-perfect-weekend-in-leavenworth-wa" class="spotlight" style="background-image:url('/images/leavenworth/hero-front-street.jpg');">
        <div class="spotlight__content">
          <span class="spotlight__badge">Featured</span>
          <h2 class="spotlight__title">The Perfect Weekend in Leavenworth</h2>
          <span class="spotlight__btn">Read the Guide →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- GUIDE PICKS — 3 cards, image-forward, no descriptions -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="picks-grid">
        {latestArticles.map((article, i) => (
          <a href={`/guides/${article.slug}`} class={`pick-card ${i === 0 ? 'pick-card--large' : ''}`}>
            <div class="pick-card__img" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#CC5500,#ff8c42)'};`}>
              {article.data.heroImage ? (
                <img src={article.data.heroImage} alt="" loading="lazy" />
              ) : (
                <span class="pick-card__emoji">{article.data.thumbnail || '📖'}</span>
              )}
              <span class="pick-card__cat">{article.data.category}</span>
            </div>
            <h3 class="pick-card__title">{shortTitles[article.slug] || article.data.title}</h3>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top:1.25rem;">
        <a href="/guides" class="btn btn--outline btn--sm">See all 18 guides →</a>
      </div>
    </div>
  </section>

  <!-- TRUST LINE — one single scannable line -->
  <div class="trust-line">
    <span>18 guides</span>
    <span class="trust-line__dot">·</span>
    <span>Family tested</span>
    <span class="trust-line__dot">·</span>
    <span>Based in the PNW</span>
  </div>

  <!-- NEWSLETTER — compact, inline -->
  <section class="section section--dark" id="newsletter">
    <div class="newsletter newsletter--compact">
      <h2 class="newsletter__title">Weekend ideas, weekly 📬</h2>
      <form class="newsletter__form" action="https://formsubmit.co/vkarthickprabu@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New Weekend Basecamp subscriber" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://weekendbasecamp.com/?subscribed=1" />
        <input type="email" name="email" placeholder="your@email.com" required class="newsletter__input" />
        <button type="submit" class="newsletter__btn">Subscribe</button>
      </form>
      <p class="newsletter__fine-print">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
