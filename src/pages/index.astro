---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Plan Your Weekend" description="Weekend destination guides and activity plans for couples, families, friends, and solo adventurers. Based in the Pacific Northwest.">
  <Header slot="header" />

  <!-- HERO — one line, that's it -->
  <section class="hero hero--minimal">
    <div class="hero__inner">
      <h1 class="hero__title">Plan your weekend.</h1>
    </div>
  </section>

  <!-- DUAL PATH — the main interaction -->
  <section class="section" style="padding-top:0;padding-bottom:1rem;">
    <div class="container">
      <div class="dual-path">
        <a href="#browse" class="path-card path-card--ideas">
          <span class="path-card__icon">💡</span>
          <h2 class="path-card__title">I need ideas</h2>
          <p class="path-card__desc">Pick your crew, get tailored plans</p>
          <span class="path-card__arrow">↓</span>
        </a>
        <a href="#destinations" class="path-card path-card--destination">
          <span class="path-card__icon">🗺️</span>
          <h2 class="path-card__title">I know where</h2>
          <p class="path-card__desc">Jump to a destination guide</p>
          <span class="path-card__arrow">↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- BROWSE BY CREW — persona chips -->
  <section class="section section--flush" id="browse">
    <div class="container">
      <p class="section__label">Who's coming?</p>
      <div class="crew-chips">
        <a href="/for/couples" class="crew-chip" style="--chip-bg:#fce4ec;--chip-accent:#e91e63;">
          <span class="crew-chip__emoji">💑</span>
          <span class="crew-chip__label">Couples</span>
        </a>
        <a href="/for/family-with-little-ones" class="crew-chip" style="--chip-bg:#e8f5e9;--chip-accent:#43a047;">
          <span class="crew-chip__emoji">👶</span>
          <span class="crew-chip__label">Little Ones</span>
        </a>
        <a href="/for/family-with-teens" class="crew-chip" style="--chip-bg:#e0f2f1;--chip-accent:#00897b;">
          <span class="crew-chip__emoji">🧑‍🤝‍🧑</span>
          <span class="crew-chip__label">Teens</span>
        </a>
        <a href="/for/friends" class="crew-chip" style="--chip-bg:#fff3e0;--chip-accent:#ef6c00;">
          <span class="crew-chip__emoji">🍻</span>
          <span class="crew-chip__label">Friends</span>
        </a>
        <a href="/for/girls-weekend" class="crew-chip" style="--chip-bg:#f3e5f5;--chip-accent:#8e24aa;">
          <span class="crew-chip__emoji">👩‍👩‍👧</span>
          <span class="crew-chip__label">Girls'</span>
        </a>
        <a href="/for/active-seniors" class="crew-chip" style="--chip-bg:#e8f5e9;--chip-accent:#558b2f;">
          <span class="crew-chip__emoji">🌿</span>
          <span class="crew-chip__label">Seniors</span>
        </a>
        <a href="/for/solo" class="crew-chip" style="--chip-bg:#e3f2fd;--chip-accent:#1565c0;">
          <span class="crew-chip__emoji">🎒</span>
          <span class="crew-chip__label">Solo</span>
        </a>
      </div>
    </div>
  </section>

  <!-- DESTINATIONS -->
  <section class="section section--flush" id="destinations">
    <div class="container">
      <p class="section__label">Where to?</p>
      <a href="/leavenworth" class="dest-card" style="background-image:url('/images/leavenworth/hero-front-street.jpg');">
        <div class="dest-card__overlay">
          <h2 class="dest-card__title">Leavenworth, WA</h2>
          <p class="dest-card__sub">Full destination guide · Written by a local</p>
        </div>
      </a>
      <div class="dest-coming">
        <span class="dest-coming__item">🌊 Olympic Peninsula — coming soon</span>
        <span class="dest-coming__item">🏝️ San Juan Islands — coming soon</span>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="section section--dark" id="newsletter">
    <div class="newsletter newsletter--compact">
      <h2 class="newsletter__title">Weekend ideas, weekly 📬</h2>
      <form class="newsletter__form" action="https://formsubmit.co/vkarthickprabu@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New Weekend Basecamp subscriber" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://weekendbasecamp.com/?subscribed=1" />
        <input type="email" name="email" placeholder="your@email.com" required class="newsletter__input" />
        <button type="submit" class="newsletter__btn">Subscribe</button>
      </form>
      <p class="newsletter__fine-print">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
