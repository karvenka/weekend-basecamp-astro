---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KitFinder from '../components/KitFinder.astro';
import SocialProof from '../components/SocialProof.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const featured = allArticles.slice(0, 6);
---
<BaseLayout title="Home" description="Guides & Gear That Help You Build Memories">
  <Header slot="header" />

  <section style="max-width:900px;margin:0 auto;padding:32px 24px 16px;text-align:center;">
    <h1 style="font-size:clamp(2rem,5vw,3.25rem);font-weight:900;line-height:1.1;color:#2c2c2c;margin:0 0 1rem;">
      Guides &amp; Gear That Help You Build Memories
    </h1>
    <p style="font-size:1.05rem;color:#6b5c4c;max-width:560px;margin:0 auto 0.75rem;line-height:1.5;">
      With family, friends, and the people who matter most. Get together. Have fun. Grow closer.
    </p>
  </section>

  <KitFinder />

  {featured.length > 0 && (
    <section style="margin:3rem 0 2rem;padding:0 24px;">
      <h2 style="font-size:1.6rem;font-weight:800;margin-bottom:1.5rem;">Featured Guides</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
        {featured.map(article => (
          <a href={`/blogs/low-effort-weekends/${article.slug}`} style="display:block;background:#fff;border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;box-shadow:0 2px 8px rgba(0,0,0,0.06);transition:transform 0.15s,box-shadow 0.15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
            <div style={`height:120px;background:${article.data.thumbnailBg || `linear-gradient(135deg,${article.data.category === 'Friends' ? '#2196F3,#64B5F6,#BBDEFB' : article.data.category === 'Couples' ? '#E91E63,#F06292,#F8BBD0' : article.data.category === 'Everyone' ? '#4CAF50,#81C784,#C8E6C9' : '#CC5500,#ff8c42,#ffd699'})`};display:flex;align-items:center;justify-content:center;font-size:3rem;`}>
              <span style="filter:drop-shadow(0 2px 8px rgba(0,0,0,0.2));">{article.data.thumbnail || (article.data.category === 'Friends' ? '👫' : article.data.category === 'Couples' ? '💑' : article.data.category === 'Everyone' ? '🌍' : '👨‍👩‍👧‍👦')}</span>
            </div>
            <div style="padding:1.25rem;">
            {article.data.category && (
              <span style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#9a7a5a;">{article.data.category}</span>
            )}
            <h3 style="margin:0.5rem 0 0.75rem;font-size:1.1rem;font-weight:700;line-height:1.3;">{article.data.title}</h3>
            {article.data.description && (
              <p style="margin:0;font-size:0.9rem;color:#6b6b6b;line-height:1.5;">{article.data.description}</p>
            )}
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/blogs/low-effort-weekends" style="display:inline-block;background:#2c2c2c;color:#f5f0e8;padding:0.75rem 2rem;border-radius:6px;text-decoration:none;font-weight:600;font-size:1rem;">Browse All Guides →</a>
      </div>
    </section>
  )}

  
  <SocialProof />

  <section style="margin:3rem 0 2rem;padding:2rem 24px;background:#1a1a1a;text-align:center;">
    <h2 style="font-size:1.4rem;font-weight:800;color:#f5f0e8;margin:0 0 0.5rem;">Get weekend ideas in your inbox</h2>
    <p style="font-size:0.95rem;color:#a89880;margin:0 0 1.25rem;max-width:480px;margin-left:auto;margin-right:auto;">One email per week. Curated kits, new guides, and the occasional product we can't stop recommending.</p>
    <form style="display:flex;gap:8px;max-width:420px;margin:0 auto;flex-wrap:wrap;justify-content:center;" action="https://formsubmit.co/vkarthickprabu@gmail.com" method="POST">
      <input type="hidden" name="_subject" value="New Weekend Basecamp subscriber" /><input type="hidden" name="_captcha" value="false" /><input type="hidden" name="_next" value="https://weekendbasecamp.com/?subscribed=1" />
      <input type="email" name="email" placeholder="your@email.com" required style="flex:1;min-width:200px;padding:10px 14px;border:none;border-radius:6px;font-size:0.95rem;" />
      <button type="submit" style="padding:10px 20px;background:#CC5500;color:#fff;border:none;border-radius:6px;font-weight:700;font-size:0.95rem;cursor:pointer;white-space:nowrap;">Subscribe</button>
    </form>
    <p style="font-size:0.75rem;color:#666;margin-top:0.75rem;">No spam. Unsubscribe anytime.</p>
  </section>

  <Footer slot="footer" />
</BaseLayout>
