---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = [...allArticles].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 6);
const seasonal = allArticles.filter(a => a.data.category === 'Seasonal');
const latestSeasonal = seasonal.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())[0];
---
<BaseLayout title="Weekend Destination Guides & Activity Ideas" description="Weekend destination guides and outdoor activity ideas for the Pacific Northwest — written from experience by a family that actually does this stuff.">
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__inner">
      <span class="hero__tagline">Pacific Northwest Weekend Guides</span>
      <h1 class="hero__title">Your weekends deserve<br/>better than the couch.</h1>
      <p class="hero__subtitle">
        Destination guides, outdoor adventures, and weekend ideas — written from experience
        by a PNW family that actually does this stuff.
      </p>
      <a href="/guides/the-perfect-weekend-in-leavenworth-wa" class="hero__cta">
        🏔️ Start with Leavenworth
      </a>
    </div>
  </section>

  <!-- FEATURED DESTINATION -->
  <section class="section">
    <div class="container">
      <a href="/guides/the-perfect-weekend-in-leavenworth-wa" class="spotlight" style="background-image:url('/images/leavenworth/hero-front-street.jpg');">
        <div class="spotlight__content">
          <div class="spotlight__label">
            <span style="font-size:1.5rem;">🏔️</span>
            <span class="spotlight__label-text">Featured Destination</span>
          </div>
          <h2 class="spotlight__title">The Perfect Weekend in Leavenworth, WA</h2>
          <p class="spotlight__desc">From a local who owns two places there and visits 15+ times a year.</p>
          <span class="spotlight__btn">Read the Guide →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- SEASONAL SPOTLIGHT -->
  {latestSeasonal && (
    <section style="padding:0 1rem 1.5rem;">
      <div class="container">
        <a href={`/guides/${latestSeasonal.slug}`} class="seasonal-banner">
          <span class="seasonal-banner__badge">This Weekend</span>
          <h3 class="seasonal-banner__title">{latestSeasonal.data.title.replace(/:.*/,'').trim()} 🇺🇸</h3>
          <span class="seasonal-banner__arrow">Read →</span>
        </a>
      </div>
    </section>
  )}

  <!-- BROWSE BY CATEGORY -->
  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <h2 class="section__title">Browse by Category</h2>
      <div class="card-grid card-grid--4">
        <a href="/guides/outdoor" class="cat-card" style="background:linear-gradient(135deg,#56ab2f,#a8e063);">
          <span class="cat-card__emoji">🏕️</span>
          <span class="cat-card__name">Outdoor</span>
          <span class="cat-card__desc">Hikes, camping, and fresh air</span>
        </a>
        <a href="/guides/couples" class="cat-card" style="background:linear-gradient(135deg,#E91E63,#F06292);">
          <span class="cat-card__emoji">❤️</span>
          <span class="cat-card__name">Couples</span>
          <span class="cat-card__desc">Date nights and romantic getaways</span>
        </a>
        <a href="/guides/family" class="cat-card" style="background:linear-gradient(135deg,#4CAF50,#81C784);">
          <span class="cat-card__emoji">👨‍👩‍👧‍👦</span>
          <span class="cat-card__name">Family</span>
          <span class="cat-card__desc">Kid-tested weekend ideas</span>
        </a>
        <a href="/guides/friends" class="cat-card" style="background:linear-gradient(135deg,#2196F3,#64B5F6);">
          <span class="cat-card__emoji">🎉</span>
          <span class="cat-card__name">Friends</span>
          <span class="cat-card__desc">Game nights, parties, group fun</span>
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST GUIDES -->
  {latestArticles.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section__title">Latest Guides</h2>
        <div class="card-grid card-grid--3">
          {latestArticles.map(article => (
            <a href={`/guides/${article.slug}`} class="guide-card">
              <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#CC5500,#ff8c42)'};`}>
                {article.data.heroImage ? (
                  <img src={article.data.heroImage} alt={article.data.title} loading="lazy" />
                ) : (
                  <span style="filter:drop-shadow(0 2px 8px rgba(0,0,0,0.2));">{article.data.thumbnail || '📖'}</span>
                )}
              </div>
              <div class="guide-card__body">
                {article.data.category && (
                  <span class="guide-card__cat">{article.data.category}</span>
                )}
                <h3 class="guide-card__title">{article.data.title}</h3>
                {article.data.description && (
                  <p class="guide-card__desc">{article.data.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-2">
          <a href="/guides" class="btn btn--dark">Browse All Guides →</a>
        </div>
      </div>
    </section>
  )}

  <!-- SOCIAL PROOF -->
  <section class="section section--alt">
    <div class="container text-center">
      <h2 class="section__title" style="text-align:center;">Real guides from real weekends</h2>

      <div class="trust-stats">
        <div class="trust-stat">
          <span class="trust-stat__number">18</span>
          <span class="trust-stat__label">Guides</span>
        </div>
        <div class="trust-stat">
          <span class="trust-stat__number">100%</span>
          <span class="trust-stat__label">Family Tested</span>
        </div>
        <div class="trust-stat">
          <span class="trust-stat__number">15+</span>
          <span class="trust-stat__label">Leavenworth Trips/Year</span>
        </div>
      </div>

      <div class="trust-quotes">
        <a href="/guides/25-at-home-date-night-ideas" class="trust-quote">
          <blockquote>"The secret to a great date night isn't spending more money — it's spending more attention."</blockquote>
          <cite>— from <strong>25 At-Home Date Night Ideas</strong></cite>
        </a>
        <a href="/guides/the-no-stress-family-hiking-guide" class="trust-quote">
          <blockquote>"The goal of a family hike isn't the summit. It's the car ride home where nobody is crying."</blockquote>
          <cite>— from <strong>The No-Stress Family Hiking Guide</strong></cite>
        </a>
        <a href="/guides/weekend-activities-for-kids-that-dont-involve-screens" class="trust-quote">
          <blockquote>"We declared a screen-free Saturday once, expecting a riot. Instead, we had the best family day we'd had in months."</blockquote>
          <cite>— from <strong>Weekend Activities for Kids</strong></cite>
        </a>
      </div>

      <div class="trust-badges">
        <span class="trust-badge">🏕️ Real family tested</span>
        <span class="trust-badge">💰 Budget-friendly picks</span>
        <span class="trust-badge">🔄 Updated regularly</span>
        <span class="trust-badge">🌲 Based in the PNW</span>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="section section--dark" id="newsletter">
    <div class="newsletter">
      <div class="newsletter__icon">📬</div>
      <h2 class="newsletter__title">Get weekend ideas in your inbox</h2>
      <p class="newsletter__desc">One email per week. New guides, seasonal ideas, and the occasional hidden gem we can't stop recommending.</p>
      <form class="newsletter__form" action="https://formsubmit.co/vkarthickprabu@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New Weekend Basecamp subscriber" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://weekendbasecamp.com/?subscribed=1" />
        <input type="email" name="email" placeholder="your@email.com" required class="newsletter__input" />
        <button type="submit" class="newsletter__btn">Subscribe</button>
      </form>
      <p class="newsletter__fine-print">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
