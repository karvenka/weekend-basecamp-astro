---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Romantic Leavenworth Getaway",
    hook: "Wine tasting, cozy village walks, dinner for two",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/leavenworth",
    color: "#e91e63"
  },
  {
    title: "The Perfect At-Home Date Weekend",
    hook: "Friday cocktails → Saturday cook-off → Sunday brunch in bed",
    type: "At Home",
    duration: "Full Weekend",
    emoji: "🕯️",
    link: "/guides/25-at-home-date-night-ideas",
    color: "#9c27b0"
  },
  {
    title: "Starlit Camping Weekend",
    hook: "Pitch a tent, build a fire, find the constellations",
    type: "Getaway",
    duration: "Overnight",
    emoji: "🌌",
    link: "/guides/weekend-camping-for-couples-who-dont-camp",
    color: "#1a237e"
  },
  {
    title: "Rainy Day Game Marathon",
    hook: "Board games, snacks, and zero reason to leave the couch",
    type: "At Home",
    duration: "Saturday",
    emoji: "🎲",
    link: "/guides/12-best-board-games-for-couples",
    color: "#00695c"
  }
];
---
<BaseLayout title="Couples Weekend Plans | Weekend Basecamp" description="Weekend plans for two — romantic getaways, at-home date nights, and adventures designed for couples.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">💑</span>
        <h1 class="persona-page__title">Couples</h1>
        <p class="persona-page__intro">The best weekends we've had cost less than a tank of gas. These are actual weekend plans — not a list of random articles.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
