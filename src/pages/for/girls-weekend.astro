---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Girls' Getaway: Leavenworth",
    hook: "Wine tasting, village shopping, spa vibes, zero agendas",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/guides/the-perfect-weekend-in-leavenworth-wa",
    color: "#8e24aa"
  },
  {
    title: "The Ultimate Girls' Night In",
    hook: "Cocktails, cooking together, blankets, staying up too late",
    type: "At Home",
    duration: "Friday Night",
    emoji: "🥂",
    link: "/guides/25-at-home-date-night-ideas",
    color: "#e91e63"
  },
  {
    title: "Brunch & Stargazing Weekend",
    hook: "Lazy morning brunch, easy day, clear-sky stargazing at night",
    type: "At Home",
    duration: "Full Weekend",
    emoji: "🌌",
    link: "/guides/the-lazy-sunday-brunch-kit",
    color: "#1a237e"
  }
];
---
<BaseLayout title="Girls' Weekend Plans | Weekend Basecamp" description="Weekend plans for you and your people. Getaways, nights in, and zero-agenda plans that feel like a reset.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">👩‍👩‍👧</span>
        <h1 class="persona-page__title">Girls' Weekend</h1>
        <p class="persona-page__intro">Your people, your weekend. Plans that feel like a reset — whether that's a getaway or just a really good night in.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
