---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Leavenworth Adventure Weekend",
    hook: "Village by day, hiking trails, tubing on the river",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/guides/the-perfect-weekend-in-leavenworth-wa",
    color: "#00897b"
  },
  {
    title: "The Challenge Weekend",
    hook: "Rock climbing Saturday, trail running Sunday. No phones.",
    type: "Day Trip",
    duration: "Full Weekend",
    emoji: "💪",
    link: "/guides/rock-climbing-for-beginners",
    color: "#d84315"
  },
  {
    title: "The Unplugged Challenge",
    hook: "48 hours, zero screens. Harder than it sounds. Better than you'd think.",
    type: "At Home",
    duration: "Full Weekend",
    emoji: "📵",
    link: "/guides/the-unplugged-weekend-challenge",
    color: "#37474f"
  },
  {
    title: "Ultimate Game Marathon",
    hook: "Strategic games, tournament brackets, bragging rights for a month",
    type: "At Home",
    duration: "Saturday",
    emoji: "🎯",
    link: "/guides/the-ultimate-game-night-guide",
    color: "#1565c0"
  }
];
---
<BaseLayout title="Weekend Plans for Families with Teens | Weekend Basecamp" description="Weekend ideas teens won't eye-roll at. Adventures, challenges, and plans that actually get them off the couch.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">🧑‍🤝‍🧑</span>
        <h1 class="persona-page__title">Family with Teens</h1>
        <p class="persona-page__intro">Adventures they won't eye-roll at. Plans that actually get everyone off the couch and into the same room — or trail.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
