---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Solo Leavenworth Weekend",
    hook: "Your pace, your plan. Best solo dining, hiking alone tips, quiet corners",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/guides/the-perfect-weekend-in-leavenworth-wa",
    color: "#1565c0"
  },
  {
    title: "Push Your Limits Weekend",
    hook: "Rock climbing Saturday, trail running Sunday. Test yourself.",
    type: "Day Trip",
    duration: "Full Weekend",
    emoji: "💪",
    link: "/guides/rock-climbing-for-beginners",
    color: "#d84315"
  },
  {
    title: "Solo Camping Reset",
    hook: "Just you, a tent, and no one asking what you want for dinner",
    type: "Getaway",
    duration: "Overnight",
    emoji: "⛺",
    link: "/guides/weekend-camping-for-couples-who-dont-camp",
    color: "#2e7d32"
  },
  {
    title: "The Unplugged Solo Weekend",
    hook: "48 hours, zero screens. Read, cook, walk, think.",
    type: "At Home",
    duration: "Full Weekend",
    emoji: "📵",
    link: "/guides/the-unplugged-weekend-challenge",
    color: "#37474f"
  }
];
---
<BaseLayout title="Solo Weekend Plans | Weekend Basecamp" description="Weekend plans for one. Solo getaways, personal challenges, and at-home resets that don't require anyone else's schedule.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">🎒</span>
        <h1 class="persona-page__title">Solo</h1>
        <p class="persona-page__intro">Just you and the weekend. Plans that don't require anyone else's schedule, opinions, or approval.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
