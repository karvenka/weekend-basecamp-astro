---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const personaSlug = 'active-seniors';
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.personas?.includes(personaSlug))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Weekend Ideas for Active Seniors | Weekend Basecamp" description="Stay moving, stay curious. Weekend ideas for people who've earned the right to spend their time exactly how they want.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Pick a different crew</a>

      <div class="persona-page__hero" style="--persona-accent:#558b2f;">
        <span class="persona-page__emoji">🌿</span>
        <h1 class="persona-page__title">Active Seniors</h1>
        <p class="persona-page__intro">You've earned the right to spend your weekends exactly how you want. These guides are for people who'd rather be on a trail than on a couch — who think retirement means more time for the good stuff, not less.</p>
      </div>

      <div class="card-grid card-grid--2">
        {articles.map(article => (
          <a href={`/guides/${article.slug}`} class="guide-card">
            <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#689F38,#AED581)'};`}>
              <span class="guide-card__emoji">{article.data.thumbnail || '📖'}</span>
            </div>
            <div class="guide-card__body">
              <h2 class="guide-card__title">{article.data.title}</h2>
            </div>
          </a>
        ))}
      </div>

      <div class="persona-page__leavenworth">
        <a href="/guides/the-perfect-weekend-in-leavenworth-wa">
          🏔️ <strong>Leavenworth is walkable and gorgeous.</strong> Bavarian charm, easy trails, great restaurants — and you can do it all at your own pace. Check our guide. →
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
