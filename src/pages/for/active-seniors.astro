---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Leavenworth at Your Pace",
    hook: "Easy village walks, wine rooms, scenic drives, no rushing",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/guides/the-perfect-weekend-in-leavenworth-wa",
    color: "#558b2f"
  },
  {
    title: "Morning Hike, Afternoon Nap",
    hook: "Easy trails, wildflowers, a packed lunch, then a well-earned rest",
    type: "Day Trip",
    duration: "Saturday",
    emoji: "🥾",
    link: "/guides/the-no-stress-family-hiking-guide",
    color: "#43a047"
  },
  {
    title: "The Lazy Sunday Brunch",
    hook: "Farmer's market finds, slow cooking, and a really good cup of coffee",
    type: "At Home",
    duration: "Sunday",
    emoji: "☕",
    link: "/guides/the-lazy-sunday-brunch-kit",
    color: "#8d6e63"
  },
  {
    title: "Backyard Evening Under the Stars",
    hook: "Fire pit, blankets, a little stargazing, early bedtime",
    type: "At Home",
    duration: "Saturday Night",
    emoji: "🌌",
    link: "/guides/the-stargazing-night-guide",
    color: "#1a237e"
  }
];
---
<BaseLayout title="Weekend Plans for Active Seniors | Weekend Basecamp" description="Weekend plans at your pace. Easy hikes, scenic getaways, and at-home plans that keep you moving and curious.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">🌿</span>
        <h1 class="persona-page__title">Active Seniors</h1>
        <p class="persona-page__intro">Stay moving, stay curious. Weekend plans at a pace that lets you actually enjoy the scenery instead of racing past it.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
