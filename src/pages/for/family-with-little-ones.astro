---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const personaSlug = 'family-littles';
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.personas?.includes(personaSlug))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Weekend Ideas for Families with Little Ones | Weekend Basecamp" description="Weekend ideas that work when nap schedules are non-negotiable and someone always needs a snack. Tested with kids under 6.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Pick a different crew</a>

      <div class="persona-page__hero" style="--persona-accent:#43a047;">
        <span class="persona-page__emoji">👶</span>
        <h1 class="persona-page__title">Family with Little Ones</h1>
        <p class="persona-page__intro">Nap schedules are non-negotiable. Someone always needs a snack. And the phrase "are we there yet?" starts approximately four minutes into any drive. These guides are built for all of that — tested with kids under 6 who have very strong opinions about everything.</p>
      </div>

      <div class="card-grid card-grid--2">
        {articles.map(article => (
          <a href={`/guides/${article.slug}`} class="guide-card">
            <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#4CAF50,#81C784)'};`}>
              <span class="guide-card__emoji">{article.data.thumbnail || '📖'}</span>
            </div>
            <div class="guide-card__body">
              <h2 class="guide-card__title">{article.data.title}</h2>
            </div>
          </a>
        ))}
      </div>

      <div class="persona-page__leavenworth">
        <a href="/guides/the-perfect-weekend-in-leavenworth-wa">
          🏔️ <strong>Leavenworth is incredibly kid-friendly.</strong> Our guide covers stroller-friendly walks, the train museum, and where to get the best hot chocolate. →
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
