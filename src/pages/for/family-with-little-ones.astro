---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const plans = [
  {
    title: "Leavenworth with Toddlers",
    hook: "Stroller-friendly village, train museum, ice cream stops between naps",
    type: "Getaway",
    duration: "Full Weekend",
    emoji: "🏔️",
    link: "/guides/the-perfect-weekend-in-leavenworth-wa",
    color: "#43a047"
  },
  {
    title: "Screen-Free Family Weekend",
    hook: "No devices, all fun. Cook-off, crafts, backyard games",
    type: "At Home",
    duration: "Full Weekend",
    emoji: "📵",
    link: "/guides/weekend-activities-for-kids-that-dont-involve-screens",
    color: "#00897b"
  },
  {
    title: "First Family Hike",
    hook: "Start small, snack often, end with ice cream. Repeat.",
    type: "Day Trip",
    duration: "Saturday",
    emoji: "🥾",
    link: "/guides/the-no-stress-family-hiking-guide",
    color: "#558b2f"
  },
  {
    title: "Sunday Family Cook-Off",
    hook: "Teams, mystery ingredients, taste-testing judges under age 6",
    type: "At Home",
    duration: "Sunday",
    emoji: "👨‍🍳",
    link: "/guides/the-sunday-family-cook-off",
    color: "#ef6c00"
  }
];
---
<BaseLayout title="Weekend Plans for Families with Little Ones | Weekend Basecamp" description="Weekend plans that work when nap schedules are non-negotiable. Tested with kids under 6.">
  <Header slot="header" />

  <div class="persona-page">
    <div class="container">
      <a href="/" class="persona-page__back">← Back</a>

      <div class="persona-page__hero">
        <span class="persona-page__emoji">👶</span>
        <h1 class="persona-page__title">Family with Little Ones</h1>
        <p class="persona-page__intro">Nap schedules are non-negotiable. Someone always needs a snack. These plans are built for that.</p>
      </div>

      <div class="plan-grid">
        {plans.map(plan => (
          <a href={plan.link} class="plan-card">
            <div class="plan-card__header" style={`background:${plan.color};`}>
              <span class="plan-card__emoji">{plan.emoji}</span>
            </div>
            <div class="plan-card__body">
              <div class="plan-card__badges">
                <span class="plan-card__badge">{plan.type}</span>
                <span class="plan-card__badge">{plan.duration}</span>
              </div>
              <h2 class="plan-card__title">{plan.title}</h2>
              <p class="plan-card__hook">{plan.hook}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
