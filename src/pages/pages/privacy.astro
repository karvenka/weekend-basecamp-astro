---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const year = new Date().getFullYear();
---
<BaseLayout title="Privacy Policy" description="Weekend Basecamp privacy policy — how we handle your data.">
  <Header slot="header" />

  <article style="max-width:760px;margin:4rem auto;padding:0 1.5rem;">
    <nav style="margin-bottom:2rem;font-size:0.85rem;">
      <a href="/" style="color:#9a7a5a;text-decoration:none;">Home</a>
      <span style="color:#ccc;margin:0 8px;">›</span>
      <span style="color:#888;">Privacy Policy</span>
    </nav>

    <h1 style="font-size:2.5rem;font-weight:900;line-height:1.1;margin:0 0 0.5rem;">Privacy Policy</h1>
    <p style="color:#888;font-size:0.9rem;margin-bottom:2rem;">Last updated: January {year}</p>

    <p style="font-size:1.05rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;">
      Weekend Basecamp ("we", "us", or "our") is committed to protecting your privacy. This policy explains what information we collect and how we use it.
    </p>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">Information We Collect</h2>
    <p style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1rem;">
      Weekend Basecamp is a content site. We do not require registration or login. We collect:
    </p>
    <ul style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;padding-left:1.5rem;">
      <li><strong>Usage data:</strong> Standard web analytics (page views, referral sources, device type) collected via analytics tools. This data is aggregated and anonymous.</li>
      <li><strong>Email addresses:</strong> If you subscribe to our newsletter, we store your email address to send you updates. You can unsubscribe at any time.</li>
      <li><strong>Cookies:</strong> We may use cookies for analytics and to remember your kit finder preferences. No personal data is stored in cookies.</li>
    </ul>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">Amazon Affiliate Links</h2>
    <p style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;">
      We participate in the Amazon Services LLC Associates Program. When you click an Amazon link on our site and make a purchase, Amazon may place cookies on your browser to track the referral. Amazon's privacy policy governs how that data is used. We receive a commission on qualifying purchases; we do not receive personal information about your purchases.
    </p>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">How We Use Information</h2>
    <ul style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;padding-left:1.5rem;">
      <li>To understand how visitors use the site and improve content</li>
      <li>To send newsletters to subscribers who opt in</li>
      <li>To maintain and improve site performance</li>
    </ul>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">Third-Party Services</h2>
    <p style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;">
      We may use third-party analytics and email services. These services have their own privacy policies. We do not sell your personal information to third parties.
    </p>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">Your Rights</h2>
    <p style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;">
      You may unsubscribe from our newsletter at any time using the link in any email we send. To request deletion of your data, contact us through our social channels on <a href="https://www.instagram.com/weekendbasecamp" target="_blank" rel="noopener noreferrer" style="color:#CC5500;">Instagram</a>.
    </p>

    <h2 style="font-size:1.5rem;font-weight:800;margin:2rem 0 0.75rem;">Changes to This Policy</h2>
    <p style="font-size:1rem;line-height:1.8;color:#4a4a4a;margin-bottom:1.5rem;">
      We may update this policy from time to time. The date at the top of this page reflects the most recent revision.
    </p>

    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid #e0d8ce;">
      <a href="/" style="color:#CC5500;text-decoration:none;font-weight:600;font-size:1rem;">← Back to Home</a>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
