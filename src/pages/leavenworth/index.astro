---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const subGuides = [
  {
    emoji: "🥾",
    title: "Things to Do",
    desc: "Free hikes, paid adventures, and the stuff locals actually do",
    href: "/leavenworth/things-to-do"
  },
  {
    emoji: "🍽️",
    title: "Where to Eat",
    desc: "Every restaurant worth your time, from bratwurst to tasting menus",
    href: "/leavenworth/restaurants"
  },
  {
    emoji: "🏨",
    title: "Where to Stay",
    desc: "Camping, condos, and the splurge-worthy resorts",
    href: "/leavenworth/where-to-stay"
  },
  {
    emoji: "🌸",
    title: "Seasonal Guide",
    desc: "What to expect spring, summer, fall, and winter",
    href: "/leavenworth/seasonal"
  },
  {
    emoji: "🚗",
    title: "Getting There",
    desc: "Routes, parking, winter driving, and when to leave Seattle",
    href: "/leavenworth/getting-there"
  },
  {
    emoji: "🅿️",
    title: "Parking",
    desc: "Which lots fill first and the strategy nobody tells you",
    href: "/leavenworth/parking"
  },
  {
    emoji: "🐕",
    title: "Dog-Friendly",
    desc: "Patios, trails, water access, and emergency vet info",
    href: "/leavenworth/dog-friendly"
  },
  {
    emoji: "👶",
    title: "With Kids",
    desc: "Stroller-friendly routes, snack stops, and age-specific activities",
    href: "/leavenworth/with-kids"
  }
];

const seasonal = [
  {
    emoji: "🍺",
    title: "Oktoberfest 2026",
    desc: "Oct 2–17 · Which weekend to pick, parking, cost breakdown",
    href: "/leavenworth/oktoberfest",
    badge: "Oct 2–17"
  },
  {
    emoji: "🎄",
    title: "Christmas & Village of Lights",
    desc: "Lighting ceremonies, the secret January window, and what to wear",
    href: "/leavenworth/christmas",
    badge: "Nov–Feb"
  }
];

const comingSoon = [
  { emoji: "💑", title: "Romantic Weekend", desc: "Wine, walks, dinner for two" },
  { emoji: "🍻", title: "Group Trip", desc: "Big tables, cabins, and activities for 6+" },
];
---
<BaseLayout
  title="Leavenworth, WA — A Local's Guide"
  description="The only Leavenworth WA guide written by a local who visits 15+ times a year. Restaurants, hikes, parking tips, dog-friendly spots, where to stay, and seasonal advice for the perfect weekend."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristDestination",
      "name": "Leavenworth, Washington",
      "description": "A Bavarian-themed village in the Cascade Mountains of Washington state, known for festivals, hiking, German cuisine, and year-round outdoor adventures.",
      "url": "https://weekendbasecamp.com/leavenworth/",
      "touristType": ["Couples", "Families", "Friends", "Solo travelers", "Dog owners", "Active seniors"],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.5955,
        "longitude": -120.6620
      },
      "containedInPlace": {
        "@type": "State",
        "name": "Washington",
        "containedInPlace": {
          "@type": "Country",
          "name": "United States"
        }
      }
    })} />
  </Fragment>
  <Header slot="header" />

  <!-- HUB HERO -->
  <section class="hub-hero" style="background-image:url('/images/leavenworth/hero-front-street.jpg');">
    <div class="hub-hero__overlay">
      <div class="hub-hero__inner">
        <p class="hub-hero__label">Destination Guide</p>
        <h1 class="hub-hero__title">Leavenworth, WA</h1>
        <p class="hub-hero__subtitle">A local's guide to the Bavarian village in the Cascades</p>
      </div>
    </div>
  </section>

  <!-- QUICK NAV -->
  <nav class="hub-nav" aria-label="Guide sections">
    <div class="hub-nav__track">
      <a href="/leavenworth/things-to-do" class="hub-nav__pill">Things to Do</a>
      <a href="/leavenworth/restaurants" class="hub-nav__pill">Where to Eat</a>
      <a href="/leavenworth/where-to-stay" class="hub-nav__pill">Where to Stay</a>
      <a href="/leavenworth/parking" class="hub-nav__pill">Parking</a>
      <a href="/leavenworth/with-kids" class="hub-nav__pill">With Kids</a>
      <a href="/leavenworth/dog-friendly" class="hub-nav__pill">Dog-Friendly</a>
      <a href="/leavenworth/oktoberfest" class="hub-nav__pill">Oktoberfest</a>
      <a href="/leavenworth/christmas" class="hub-nav__pill">Christmas</a>
      <a href="/leavenworth/seasonal" class="hub-nav__pill">Seasonal</a>
      <a href="/leavenworth/getting-there" class="hub-nav__pill">Getting There</a>
    </div>
  </nav>

  <!-- INTRO -->
  <section class="section">
    <div class="container--narrow">
      <p class="hub-intro">
        I own a place here and visit 15+ times a year. This isn't a travel blog cobbled together from other travel blogs. These are my actual recommendations — every restaurant, every trail, every insider tip is from personal experience.
      </p>
    </div>
  </section>

  <!-- INTERACTIVE MAP -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div id="leavenworth-map" class="interactive-map"></div>
      <div class="map-legend">
        <span class="legend-item"><span class="legend-dot" style="background:#e74c3c;"></span> Restaurants</span>
        <span class="legend-item"><span class="legend-dot" style="background:#3498db;"></span> Things to Do</span>
        <span class="legend-item"><span class="legend-dot" style="background:#2ecc71;"></span> Parking</span>
        <span class="legend-item"><span class="legend-dot" style="background:#9b59b6;"></span> Lodging</span>
      </div>
    </div>
  </section>

  <!-- WHO'S COMING — persona filter chips -->
  <section class="section section--flush" style="padding-bottom:1rem;">
    <div class="container">
      <p class="section__label">Who's coming?</p>
      <div class="persona-chips">
        <a href="/leavenworth/with-kids/" class="persona-chip">👶 With Kids</a>
        <a href="/leavenworth/dog-friendly/" class="persona-chip">🐕 Dog-Friendly</a>
        <span class="persona-chip persona-chip--soon">💑 Couples <span class="persona-chip__badge">Soon</span></span>
        <span class="persona-chip persona-chip--soon">🍻 Group Trip <span class="persona-chip__badge">Soon</span></span>
      </div>
    </div>
  </section>

  <!-- SUB-GUIDE CARDS -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="hub-cards">
        {subGuides.map(g => (
          <a href={g.href} class="hub-card">
            <span class="hub-card__emoji">{g.emoji}</span>
            <div>
              <h2 class="hub-card__title">{g.title}</h2>
              <p class="hub-card__desc">{g.desc}</p>
            </div>
            <span class="hub-card__arrow">→</span>
          </a>
        ))}
      </div>

      <!-- Seasonal Events -->
      <h3 class="hub-coming-label" style="margin-top:1.5rem;">Seasonal Events</h3>
      <div class="hub-cards">
        {seasonal.map(g => (
          <a href={g.href} class="hub-card hub-card--seasonal">
            <span class="hub-card__emoji">{g.emoji}</span>
            <div>
              <h2 class="hub-card__title">{g.title}</h2>
              <p class="hub-card__desc">{g.desc}</p>
            </div>
            <span class="hub-card__badge">{g.badge}</span>
          </a>
        ))}
      </div>

      <!-- Coming soon -->
      <h3 class="hub-coming-label">More guides on the way</h3>
      <div class="hub-cards hub-cards--coming">
        {comingSoon.map(g => (
          <div class="hub-card hub-card--coming">
            <span class="hub-card__emoji">{g.emoji}</span>
            <div>
              <h2 class="hub-card__title">{g.title}</h2>
              <p class="hub-card__desc">{g.desc}</p>
            </div>
            <span class="hub-card__soon">Soon</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LIVE WEBCAMS — YouTube Live Embeds -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:0.25rem;">📹 Live Webcams</h2>
      <p style="font-size:0.85rem;color:#666;margin-bottom:0.75rem;">See what Leavenworth looks like right now</p>
      <div class="webcam-grid">
        <div class="webcam-card">
          <iframe src="https://www.youtube.com/embed/XjhxRZEm638?autoplay=0" title="Downtown Leavenworth Live Webcam" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          <div class="webcam-card__label">🎥 Downtown <span>· Village view</span></div>
        </div>
        <div class="webcam-card">
          <iframe src="https://www.youtube.com/embed/yHH8EWIR01Y?autoplay=0" title="Rhein Haus Leavenworth Live Webcam" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          <div class="webcam-card__label">🎥 Rhein Haus <span>· Front Street</span></div>
        </div>
        <div class="webcam-card">
          <iframe src="https://www.youtube.com/embed/TmtVbezZaqg?autoplay=0" title="Kris Kringl Leavenworth Live Webcam" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          <div class="webcam-card__label">🎥 Kris Kringl <span>· Front Street</span></div>
        </div>
        <div class="webcam-card">
          <iframe src="https://www.youtube.com/embed/s869fYS-TGY?autoplay=0" title="Leavenworth Adventure Park Live Webcam" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          <div class="webcam-card__label">🎥 Adventure Park <span>· Alpine coaster</span></div>
        </div>
      </div>
      <div class="webcam-extras">
        <a href="https://www.youtube.com/watch?v=NdW8Mh0lmOo" target="_blank" rel="noopener">🎥 Mountain Modern cam</a>
        <a href="https://www.stevenspass.com/the-mountain/mountain-conditions/mountain-cams.aspx" target="_blank" rel="noopener">⛷️ Stevens Pass cams</a>
        <a href="https://wsdot.com/travel/real-time/mountainpasses/stevens" target="_blank" rel="noopener">🛣️ WSDOT road conditions</a>
        <a href="https://leavenworth.org/webcams/" target="_blank" rel="noopener">📹 All official cams</a>
      </div>
    </div>
  </section>

  <!-- FACTS STRIP -->
  <section class="hub-facts">
    <div class="container">
      <div class="hub-facts__row">
        <span class="hub-facts__item">📍 2.5 hrs from Seattle</span>
        <span class="hub-facts__item">🏔️ Elevation: 1,170 ft</span>
        <span class="hub-facts__item">👤 Population: ~2,000</span>
        <span class="hub-facts__item">⭐ Best season: All of them</span>
      </div>
    </div>
  </section>

  <!-- FULL GUIDE LINK -->
  <section class="section" style="text-align:center;">
    <div class="container--narrow">
      <p style="color:#6b5c4c;font-size:0.9rem;margin:0 0 0.75rem;">Want everything in one page?</p>
      <a href="/guides/the-perfect-weekend-in-leavenworth-wa" class="hub-full-link">Read the full Leavenworth guide →</a>
    </div>
  </section>

  <Footer slot="footer" />

  <!-- Leaflet Map -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var mapEl = document.getElementById('leavenworth-map');
    if (!mapEl) return;

    var map = L.map('leavenworth-map', {
      scrollWheelZoom: false
    }).setView([47.5955, -120.6620], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://openstreetmap.org">OSM</a>',
      maxZoom: 18
    }).addTo(map);

    var pins = [
      // Restaurants (red)
      {lat:47.59444,lng:-120.66301,name:"München Haus",type:"restaurant",info:"⭐ 4.5 · Bratwurst & beer garden"},
      {lat:47.59528,lng:-120.66132,name:"Andreas Keller",type:"restaurant",info:"⭐ 4.2 · Bavarian basement restaurant"},
      {lat:47.59464,lng:-120.66382,name:"Visconti's",type:"restaurant",info:"⭐ 4.7 · Italian fine dining"},
      {lat:47.59618,lng:-120.65963,name:"Icicle Brewing",type:"restaurant",info:"⭐ 4.5 · Craft beer & patio"},
      {lat:47.59451,lng:-120.66358,name:"Yodelin Broth Co",type:"restaurant",info:"⭐ 4.5 · Broth bowls & beer garden"},
      {lat:47.59581,lng:-120.66051,name:"South",type:"restaurant",info:"⭐ 4.4 · Latin American"},
      {lat:47.59174,lng:-120.67025,name:"Argonaut Coffee",type:"restaurant",info:"⭐ 4.6 · Coffee & biscuits"},
      {lat:47.59514,lng:-120.66070,name:"Tumwater Bread & Pizza",type:"restaurant",info:"⭐ 4.6 · Wood-fired pizza"},
      {lat:47.59623,lng:-120.65755,name:"Mana",type:"restaurant",info:"⭐ 4.8 · Chef's tasting menu"},
      // Activities (blue)
      {lat:47.59237,lng:-120.66360,name:"Waterfront Park & Blackbird Island",type:"activity",info:"Free · Trails along the river"},
      {lat:47.59490,lng:-120.66242,name:"Nutcracker Museum",type:"activity",info:"⭐ 4.4 · 9,000+ nutcrackers"},
      {lat:47.58718,lng:-120.67488,name:"Adventure Park",type:"activity",info:"⭐ 4.5 · Alpine coaster & climbing"},
      {lat:47.60636,lng:-120.64922,name:"Reindeer Farm",type:"activity",info:"⭐ 4.9 · Feed real reindeer"},
      {lat:47.59657,lng:-120.65895,name:"Festhalle",type:"activity",info:"Events & Oktoberfest venue"},
      // Parking (green)
      {lat:47.59590,lng:-120.66450,name:"P1 / Aasgard Lot",type:"parking",info:"Paid · Closest to west end"},
      {lat:47.59560,lng:-120.66200,name:"P2 / Blewett Lot",type:"parking",info:"Paid · Central"},
      {lat:47.59540,lng:-120.65950,name:"P3 / Colchuck Lot",type:"parking",info:"Paid · East end (less busy)"},
      {lat:47.59700,lng:-120.65800,name:"P4 / Dragontail Lot",type:"parking",info:"Paid · Near Festhalle"},
      // Lodging (purple)
      {lat:47.59427,lng:-120.66171,name:"Posthotel",type:"lodging",info:"⭐ 9.2/10 · Luxury boutique"},
    ];

    var colors = {
      restaurant: '#e74c3c',
      activity: '#3498db',
      parking: '#2ecc71',
      lodging: '#9b59b6'
    };

    pins.forEach(function(pin) {
      var color = colors[pin.type] || '#CC5500';
      var icon = L.divIcon({
        className: 'map-pin-wrap',
        html: '<div style="background:'+color+';width:14px;height:14px;border-radius:50%;border:2.5px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.35);"></div>',
        iconSize: [19, 19],
        iconAnchor: [9, 9]
      });

      var marker = L.marker([pin.lat, pin.lng], {icon: icon}).addTo(map);
      var query = encodeURIComponent(pin.name + ' Leavenworth WA');
      marker.bindPopup(
        '<div style="min-width:160px;"><strong>' + pin.name + '</strong><br>' +
        '<span style="font-size:0.85em;color:#555;">' + pin.info + '</span><br>' +
        '<a href="https://www.google.com/maps/search/?api=1&query=' + query + '" target="_blank" rel="noopener" style="font-size:0.85em;color:#CC5500;">Directions →</a></div>'
      );
    });
  });
  </script>
</BaseLayout>
