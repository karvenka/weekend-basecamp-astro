---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const destinations = allArticles.filter(a => a.data.category === 'Destinations');
destinations.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const plannedDestinations = [
  { emoji: '🏔️', name: 'Leavenworth, WA', status: 'Coming soon' },
  { emoji: '🏝️', name: 'Olympic Peninsula, WA', status: 'Planned' },
  { emoji: '⛴️', name: 'San Juan Islands, WA', status: 'Planned' },
  { emoji: '🌲', name: 'North Cascades, WA', status: 'Planned' },
  { emoji: '🏖️', name: 'Long Beach Peninsula, WA', status: 'Planned' },
  { emoji: '🍷', name: 'Walla Walla, WA', status: 'Planned' },
];
---
<BaseLayout title="Destinations" description="Weekend getaway guides written by locals who actually live nearby.">
  <Header slot="header" />

  <div style="max-width:900px;margin:3rem auto;padding:0 1.5rem;">
    <div style="margin-bottom:2.5rem;">
      <h1 style="font-size:2.5rem;font-weight:900;margin:0 0 0.75rem;color:#2c2c2c;">Destinations</h1>
      <p style="font-size:1.1rem;color:#6b5c4c;margin:0;line-height:1.5;max-width:600px;">Weekend getaway guides written by locals who actually live nearby.</p>
    </div>

    {destinations.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;margin-bottom:3rem;">
        {destinations.map(article => (
          <a href={`/guides/${article.slug}`} style="display:block;background:#fff;border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;box-shadow:0 2px 8px rgba(0,0,0,0.06);transition:transform 0.15s,box-shadow 0.15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
            <div style={`height:160px;background:${article.data.thumbnailBg || 'linear-gradient(135deg,#2d5016,#87CEEB)'};display:flex;align-items:center;justify-content:center;font-size:3.5rem;`}>
              <span style="filter:drop-shadow(0 2px 8px rgba(0,0,0,0.2));">{article.data.thumbnail || '🏔️'}</span>
            </div>
            <div style="padding:1.25rem;">
              <span style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#9a7a5a;">Destination Guide</span>
              <h2 style="margin:0.5rem 0 0.75rem;font-size:1.2rem;font-weight:700;line-height:1.3;">{article.data.title}</h2>
              {article.data.description && (
                <p style="margin:0;font-size:0.9rem;color:#6b6b6b;line-height:1.5;">{article.data.description}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="margin-bottom:3rem;">
        <div style="background:linear-gradient(135deg, #2d5016, #4a8c2a, #87CEEB);border-radius:14px;padding:2.5rem;margin-bottom:2rem;">
          <div style="max-width:550px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
              <span style="font-size:1.5rem;">🏔️</span>
              <span style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.85);">Featured Destination</span>
            </div>
            <h2 style="font-size:1.8rem;font-weight:900;line-height:1.15;margin:0 0 0.75rem;color:#fff;">The Perfect Weekend in Leavenworth, WA</h2>
            <p style="font-size:1rem;color:rgba(255,255,255,0.85);line-height:1.5;margin:0 0 1.5rem;">From a local who owns two places there and visits 15+ times a year.</p>
            <a href="/guides/the-perfect-weekend-in-leavenworth-wa" style="display:inline-block;padding:10px 24px;background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.35);border-radius:6px;font-weight:700;font-size:0.95rem;color:#fff;text-decoration:none;backdrop-filter:blur(4px);transition:background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.3)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'">Read the Guide →</a>
          </div>
        </div>

        <h3 style="font-size:1.2rem;font-weight:700;color:#2c2c2c;margin:0 0 1rem;">Coming Soon</h3>
        <p style="font-size:0.95rem;color:#6b5c4c;margin:0 0 1.5rem;">We're working on in-depth destination guides for the Pacific Northwest. Here's what's on our list:</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;">
          {plannedDestinations.map(dest => (
            <div style="background:#fff;border:1px solid #e8dfd3;border-radius:10px;padding:1.25rem;display:flex;align-items:center;gap:12px;">
              <span style="font-size:1.8rem;">{dest.emoji}</span>
              <div>
                <span style="font-weight:700;color:#2c2c2c;font-size:0.95rem;display:block;">{dest.name}</span>
                <span style="font-size:0.78rem;color:#999;">{dest.status}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <Footer slot="footer" />
</BaseLayout>
