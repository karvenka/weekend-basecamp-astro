---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const destinations = allArticles.filter(a => a.data.category === 'Destinations');
destinations.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const comingSoon = [
  { emoji: '🏝️', name: 'Olympic Peninsula, WA' },
  { emoji: '⛴️', name: 'San Juan Islands, WA' },
  { emoji: '🌲', name: 'North Cascades, WA' },
  { emoji: '🏖️', name: 'Bend, Oregon' },
];
---
<BaseLayout title="Destinations" description="Weekend getaway guides written by locals who actually live nearby.">
  <Header slot="header" />

  <div class="container" style="padding-top:3rem;padding-bottom:3rem;">
    <div class="page-header">
      <h1 class="page-header__title">Destinations</h1>
      <p class="page-header__desc">Weekend getaway guides written by locals who actually live nearby. Each guide is based on dozens of personal visits — not a quick press trip.</p>
    </div>

    <!-- Live destination guides -->
    {destinations.length > 0 && (
      <div style="margin-bottom:2.5rem;">
        {destinations.map(article => (
          <a href={`/guides/${article.slug}`} class="spotlight" style="background-image:url('/images/leavenworth/hero-front-street.jpg');margin-bottom:1.5rem;">
            <div class="spotlight__content">
              <div class="spotlight__label">
                <span style="font-size:1.5rem;">{article.data.thumbnail || '🏔️'}</span>
                <span class="spotlight__label-text">Destination Guide</span>
              </div>
              <h2 class="spotlight__title">{article.data.title}</h2>
              <p class="spotlight__desc">{article.data.description}</p>
              <span class="spotlight__btn">Read the Guide →</span>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- Coming soon -->
    <h3 style="font-size:1.1rem;font-weight:700;color:#2c2c2c;margin:0 0 1rem;">More destinations on the way</h3>
    <p style="font-size:0.95rem;color:#6b5c4c;margin:0 0 1.25rem;">We're working on in-depth guides for these PNW favorites. Each one gets the same treatment — dozens of visits, real restaurant picks, insider tips.</p>
    <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));">
      {comingSoon.map(dest => (
        <div class="coming-soon-card">
          <span class="coming-soon-card__emoji">{dest.emoji}</span>
          <div>
            <span class="coming-soon-card__name">{dest.name}</span>
            <span class="coming-soon-card__status">Coming soon</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
