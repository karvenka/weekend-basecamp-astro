---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const vibes = ['All', 'Active', 'Cozy', 'Celebratory', 'Deep', 'Family', 'Couples', 'Friends'];
---
<BaseLayout title="Guides" description="All guides from Weekend Basecamp — ideas, gear, and inspiration for real weekends.">
  <Header slot="header" />

  <div style="max-width:1000px;margin:3rem auto;padding:0 1.5rem;">
    <h1 style="font-size:2.5rem;font-weight:900;margin-bottom:0.5rem;">All Guides</h1>
    <p style="font-size:1.05rem;color:#6b5c4c;margin-bottom:2rem;">Low-effort, high-memory weekend ideas for the people you love most.</p>

    <!-- Vibe toggle pills -->
    <div class="guides-filter" id="guides-filter">
      {vibes.map(vibe => (
        <button
          class={`guide-pill${vibe === 'All' ? ' guide-pill--on' : ''}`}
          data-vibe={vibe.toLowerCase()}
          aria-pressed={vibe === 'All' ? 'true' : 'false'}
        >
          {vibe}
        </button>
      ))}
    </div>

    {articles.length === 0 && (
      <p style="color:#6b6b6b;">No guides yet. Check back soon!</p>
    )}

    <div class="guides-grid" id="guides-grid">
      {articles.map(article => (
        <a
          href={`/blogs/low-effort-weekends/${article.slug}`}
          class="guide-card"
          data-category={article.data.category?.toLowerCase() || ''}
        >
          <div class="guide-card__content">
            {article.data.category && (
              <span class="guide-card__cat">{article.data.category}</span>
            )}
            <h2 class="guide-card__title">{article.data.title}</h2>
            {article.data.description && (
              <p class="guide-card__desc">{article.data.description}</p>
            )}
            <div class="guide-card__meta">
              {article.data.readTime && <span>{article.data.readTime}</span>}
              <time datetime={article.data.pubDate.toISOString()}>
                {article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .guides-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 2rem;
  }
  .guide-pill {
    padding: 8px 18px;
    border-radius: 999px;
    border: 1.5px solid #ddd;
    background: #fff;
    color: #4a3f35;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.12s;
    font-family: inherit;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .guide-pill:hover { background: #f0e8dc; border-color: #CC5500; }
  .guide-pill--on { background: #2c2c2c; border-color: #2c2c2c; color: #fff; }

  .guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .guide-card {
    display: block;
    background: #fff;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: transform 0.15s, box-shadow 0.15s;
    overflow: hidden;
  }
  .guide-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
  .guide-card__content { padding: 1.5rem; }
  .guide-card__cat {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9a7a5a;
  }
  .guide-card__title { margin: 0.4rem 0 0.6rem; font-size: 1.1rem; font-weight: 700; line-height: 1.3; }
  .guide-card__desc { margin: 0 0 0.75rem; font-size: 0.9rem; color: #6b6b6b; line-height: 1.5; }
  .guide-card__meta { display: flex; gap: 12px; font-size: 0.8rem; color: #999; flex-wrap: wrap; }
  .guide-card--hidden { display: none; }

  @media (max-width: 600px) {
    .guides-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
(function() {
  var pills = document.querySelectorAll('.guide-pill');
  var cards = document.querySelectorAll('.guide-card');

  pills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      var vibe = pill.dataset.vibe;
      pills.forEach(function(p) {
        p.classList.remove('guide-pill--on');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('guide-pill--on');
      pill.setAttribute('aria-pressed', 'true');

      cards.forEach(function(card) {
        if (vibe === 'all') {
          card.classList.remove('guide-card--hidden');
        } else {
          var cat = (card.dataset.category || '').toLowerCase();
          if (cat.includes(vibe)) {
            card.classList.remove('guide-card--hidden');
          } else {
            card.classList.add('guide-card--hidden');
          }
        }
      });
    });
  });
})();
</script>
