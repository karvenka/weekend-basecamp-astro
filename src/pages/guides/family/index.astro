---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const familySlugs = [
  'the-no-stress-family-hiking-guide',
  'weekend-activities-for-kids-that-dont-involve-screens',
  'the-sunday-family-cook-off',
];

const allArticles = await getCollection('articles');
const articles = allArticles.filter(a =>
  a.data.category?.toLowerCase() === 'family' ||
  familySlugs.includes(a.slug) ||
  (a.data.tags && a.data.tags.some((t: string) => t.toLowerCase() === 'family'))
);
articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Family Weekend Ideas" description="Kid-tested weekend activities, family hikes, and things to do that don't involve screens.">
  <Header slot="header" />

  <div class="container" style="padding-top:3rem;padding-bottom:3rem;">
    <div class="page-header">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:0.75rem;">
        <span style="font-size:2rem;">👨‍👩‍👧‍👦</span>
        <h1 class="page-header__title" style="margin:0;">Family</h1>
      </div>
      <p class="page-header__desc">Kid-tested weekend activities, family hikes, and ideas that don't involve screens.</p>
    </div>

    <div class="card-grid card-grid--3">
      {articles.map(article => (
        <a href={`/guides/${article.slug}`} class="guide-card">
          <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#4CAF50,#81C784)'};`}>
            <span style="filter:drop-shadow(0 2px 8px rgba(0,0,0,0.2));font-size:2.5rem;">{article.data.thumbnail || '👨‍👩‍👧‍👦'}</span>
          </div>
          <div class="guide-card__body">
            <h2 class="guide-card__title">{article.data.title}</h2>
            {article.data.description && (
              <p class="guide-card__desc">{article.data.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-2">
      <a href="/guides" class="btn btn--dark">Browse All Guides →</a>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
