---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---
<BaseLayout title={article.data.title} description={article.data.description}>
  <Header slot="header" />

  <article style="max-width:760px;margin:3rem auto;padding:0 1.5rem;">
    <a href="/guides" style="display:inline-block;margin-bottom:2rem;color:#9a7a5a;text-decoration:none;font-size:0.9rem;font-weight:600;">
      ← All Guides
    </a>

    {article.data.category && (
      <span style="display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#9a7a5a;margin-bottom:0.75rem;">
        {article.data.category}
      </span>
    )}

    <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:900;line-height:1.15;margin:0 0 1rem;">{article.data.title}</h1>

    <div style="display:flex;align-items:center;gap:1.5rem;color:#888;font-size:0.875rem;margin-bottom:1rem;flex-wrap:wrap;">
      <span>By {article.data.author}</span>
      <time datetime={article.data.pubDate.toISOString()}>
        {article.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
      </time>
      {article.data.readTime && <span>{article.data.readTime}</span>}
    </div>

    <div style="display:flex;gap:8px;margin:16px 0 32px">
      <a href="#" onclick="window.open('https://twitter.com/intent/tweet?url='+encodeURIComponent(window.location.href)+'&text='+encodeURIComponent(document.title),'_blank','width=550,height=420');return false" style="padding:8px 16px;border:1px solid #ddd;border-radius:20px;text-decoration:none;color:#333;font-size:0.875rem">X</a>
      <a href="#" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u='+encodeURIComponent(window.location.href),'_blank','width=550,height=420');return false" style="padding:8px 16px;border:1px solid #ddd;border-radius:20px;text-decoration:none;color:#333;font-size:0.875rem">Facebook</a>
      <a href="#" onclick="navigator.clipboard.writeText(window.location.href).then(()=>this.textContent='Copied!');return false" style="padding:8px 16px;border:1px solid #ddd;border-radius:20px;text-decoration:none;color:#333;font-size:0.875rem;cursor:pointer">Copy Link</a>
      <a href="#" onclick="navigator.share&&navigator.share({title:document.title,url:window.location.href});return false" style="padding:8px 16px;border:1px solid #ddd;border-radius:20px;text-decoration:none;color:#333;font-size:0.875rem">Share 📣</a>
    </div>

    <div class="article-body" style="font-size:1.05rem;line-height:1.75;color:#2c2c2c;">
      <Content />
    </div>

    <style>.article-body > h1:first-child { display: none; }</style>
    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid #e0d8ce;">
      <a href="/guides" style="color:#9a7a5a;text-decoration:none;font-weight:600;">← All Guides</a>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
