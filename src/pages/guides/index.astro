---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="All Guides" description="Every Weekend Basecamp guide — destination guides, activity ideas, seasonal picks, and more.">
  <Header slot="header" />

  <div class="container" style="padding-top:3rem;padding-bottom:3rem;">
    <div class="page-header">
      <h1 class="page-header__title">All Guides</h1>
      <p class="page-header__desc">Every guide we've published — destination deep-dives, activity ideas, and seasonal picks.</p>
    </div>

    <div style="display:grid;gap:1rem;">
      {articles.map(article => (
        <a href={`/guides/${article.slug}`} class="list-card">
          <div class="list-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#CC5500,#ff8c42)'};`}>
            {article.data.thumbnail || '📖'}
          </div>
          <div class="list-card__body">
            <div>
              {article.data.category && (
                <span class="guide-card__cat">{article.data.category}</span>
              )}
              <h2 style="margin:0.35rem 0 0.4rem;font-size:1.1rem;font-weight:700;">{article.data.title}</h2>
              {article.data.description && (
                <p style="margin:0;font-size:0.88rem;color:#6b6b6b;">{article.data.description}</p>
              )}
            </div>
            <time style="font-size:0.8rem;color:#999;white-space:nowrap;" datetime={article.data.pubDate.toISOString()}>
              {article.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
