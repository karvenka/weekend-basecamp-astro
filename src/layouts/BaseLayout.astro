---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Weekend Basecamp — Guides & Gear for Family Adventures' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Weekend Basecamp</title>
  <meta name="google-site-verification" content="Wz3JkCHX0us1qU6yumBdnhHWsH7PKfdS21hu5WlRSeA" />
  <slot name="head" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: #faf7f2;
      color: #2c2c2c;
      line-height: 1.6;
    }
    a { color: inherit; }
    @media (max-width: 600px) {
      body { font-size: 16px; }
    }
  </style>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Organization","name":"Weekend Basecamp","url":"https://weekendbasecamp.com","logo":"https://weekendbasecamp.com/logo.png","description":"Guides & Gear That Help You Build Memories","sameAs":["https://www.pinterest.com/weekendbasecamp","https://www.instagram.com/weekendbasecamp"]}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"WebSite","name":"Weekend Basecamp","url":"https://weekendbasecamp.com","potentialAction":{"@type":"SearchAction","target":"https://weekendbasecamp.com/blogs/low-effort-weekends?q={search_term_string}","query-input":"required name=search_term_string"}}
</script>
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>
