---
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}
const { title, description = 'Weekend destination guides and activity ideas — written from experience by a PNW family.', canonicalUrl, ogImage } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
const socialImage = ogImage || 'https://weekendbasecamp.com/social-card.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="stylesheet" href="/styles/global.css" />
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} | Weekend Basecamp`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:site_name" content="Weekend Basecamp" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Weekend Basecamp`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />
  <meta name="pinterest-rich-pin" content="true" />
  <title>{title} | Weekend Basecamp</title>
  <meta name="google-site-verification" content="Wz3JkCHX0us1qU6yumBdnhHWsH7PKfdS21hu5WlRSeA" />
  <slot name="head" />
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Organization","name":"Weekend Basecamp","url":"https://weekendbasecamp.com","logo":"https://weekendbasecamp.com/logo.png","description":"Weekend destination guides and activity ideas for the Pacific Northwest — written from experience by a family that actually does this stuff.","sameAs":["https://www.pinterest.com/weekendbasecamp","https://www.instagram.com/weekendbasecamp"]}
</script>
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>
