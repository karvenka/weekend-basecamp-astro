        '<a class="sh-card-link" href="https://www.amazon.com/dp/' + product.asin + '?tag=weekendbasecamp-20" target="_blank" rel="noopener noreferrer nofollow" onclick="event.stopPropagation()">View on Amazon</a>' +
      '</div>' +
    '</div>';
  }

  function renderKit(kitKey) {
