    if (hookEl) {
      var vibeEmoji = storyHookEmojis[currentVibe] || '✨';
      var hookTitle = storyHookTitles[kitKey] || kit.story;
      hookEl.innerHTML = '<span class="wbs-story-hook-emoji">' + vibeEmoji + '</span>' +
