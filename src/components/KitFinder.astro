      planEl.innerHTML = steps.join('');
    }

    // SECTION 2: Render matched guide card — the WHY
    var guideEl = document.getElementById('wbs-related-guide');
    var articleUrl = kitArticleMap[kitKey];
    if (guideEl && articleUrl) {
      var articleData = {
        '/blogs/low-effort-weekends/25-at-home-date-night-ideas': {
