      };
      var data = articleData[articleUrl] || { title: 'Read the full guide', teaser: '' };
      guideEl.innerHTML = '<a href="' + articleUrl + '">' +
        '<span class="wbs-related-guide-icon">📖</span>' +
        '<div class="wbs-related-guide-text">' +
          '<div class="wbs-related-guide-label">Read the guide</div>' +
          '<div class="wbs-related-guide-title">' + escHtml(data.title) + '</div>' +
