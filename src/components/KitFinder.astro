  function updateCart() {
    var checked = document.querySelectorAll('.sh-cb:checked');
    var cartBtn = document.getElementById('sh-cart-btn');
    var summary = document.getElementById('sh-cart-summary');
    if (!checked.length) {
      if (cartBtn) { cartBtn.href = '#'; cartBtn.classList.add('sh-cart-cta--dim'); }
      if (summary) summary.textContent = 'Select items above';
      return;
    }
    var asins = Array.from(checked).map(function(cb) { return {asin: cb.dataset.asin, price: cb.dataset.price}; });
    var url = 'https://www.amazon.com/gp/aws/cart/add.html?AssociateTag=' + affiliateTag;
    asins.forEach(function(item, i) {
      url += '&ASIN.' + (i+1) + '=' + item.asin + '&Quantity.' + (i+1) + '=1';
    });
    if (cartBtn) { cartBtn.href = url; cartBtn.classList.remove('sh-cart-cta--dim'); }
    var total = asins.reduce(function(sum, item) { return sum + parsePriceNum(item.price); }, 0);
    if (summary) summary.textContent = checked.length + ' item' + (checked.length !== 1 ? 's' : '') + ' · ~$' + total;

    var kitKey = kitMap[currentWho] && kitMap[currentWho][currentVibe];
    var kit = kitKey && kits[kitKey];
    var drawer = document.getElementById('wbs-mobile-drawer');
    var drawerBtn = document.getElementById('wbs-mobile-drawer-btn');
    if (drawer && window.innerWidth < 768) {
      drawer.classList.add('active');
      if (drawerBtn) drawerBtn.href = url;
      var drawerName = document.getElementById('wbs-mobile-drawer-name');
      var drawerMeta = document.getElementById('wbs-mobile-drawer-meta');
      if (drawerName && kit) drawerName.textContent = kit.name;
      if (drawerMeta) drawerMeta.textContent = checked.length + ' items · ~$' + total;
    }
  }

  window.shareKit = function(kitKey) {
    if (!kitKey) kitKey = (kitMap[currentWho] && kitMap[currentWho][currentVibe]) || 'family_cozy';
    var articlePath = kitArticleMap[kitKey] || '/blogs/low-effort-weekends';
    var url = window.location.origin + articlePath;
    var kit = kits[kitKey];
    var title = (kit ? kit.name : kitKey) + ' — Weekend Basecamp';
    if (navigator.share) {
      navigator.share({ title: title, text: 'Check out this weekend kit!', url: url }).catch(function() {});
    } else {
      try {
        navigator.clipboard.writeText(url).then(function() {
          var toast = document.createElement('div');
          toast.textContent = 'Link copied!';
          toast.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:10px 20px;border-radius:8px;z-index:99999;font-size:14px;';
          document.body.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 2000);
        });
      } catch(e) {}
    }
  };

  document.querySelectorAll('.sh-pill').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var group = btn.dataset.group;
      var value = btn.dataset.value;
      document.querySelectorAll('.sh-pill[data-group="' + group + '"]').forEach(function(b) {
        b.classList.remove('sh-pill--on');
      });
      btn.classList.add('sh-pill--on');
      if (group === 'who') currentWho = value;
      else if (group === 'vibe') currentVibe = value;
      renderKit(kitMap[currentWho][currentVibe]);
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('who', currentWho);
        url.searchParams.set('vibe', currentVibe);
        window.history.replaceState({}, '', url.toString());
      } catch(e) {}
    });
  });

  var dismissBtn = document.getElementById('wbs-mobile-drawer-dismiss');
  if (dismissBtn) dismissBtn.addEventListener('click', function() {
    var drawer = document.getElementById('wbs-mobile-drawer');
    if (drawer) drawer.classList.remove('active');
  });

  try {
    var params = new URLSearchParams(window.location.search);
    var whoP = params.get('who');
    var vibeP = params.get('vibe');
    if (whoP && kitMap[whoP]) {
      currentWho = whoP;
      document.querySelectorAll('.sh-pill[data-group="who"]').forEach(function(b) {
        b.classList.toggle('sh-pill--on', b.dataset.value === whoP);
      });
    }
    if (vibeP && kitMap[currentWho][vibeP]) {
      currentVibe = vibeP;
      document.querySelectorAll('.sh-pill[data-group="vibe"]').forEach(function(b) {
        b.classList.toggle('sh-pill--on', b.dataset.value === vibeP);
      });
    }
  } catch(e) {}

  renderKit(kitMap[currentWho][currentVibe]);

  // === DYNAMIC IMAGE FALLBACK ===
  // Checks all product images after render. If an image fails to load or loads blank,
  // tries multiple Amazon URL patterns before falling back to SVG placeholder.
  function fixBrokenImages() {
    document.querySelectorAll('.sh-card-img img[data-asin]').forEach(function(img) {
      var asin = img.dataset.asin;
      var name = img.dataset.name || '';
      if (!asin) return;

      // Skip SVGs — they always work
      if (img.src.endsWith('.svg')) return;

      img.onerror = function() {
        var urls = [
          'https://m.media-amazon.com/images/P/' + asin + '.01._SCLZZZZZZZ_SL300_.jpg',
          'https://images-na.ssl-images-amazon.com/images/P/' + asin + '.01._SCLZZZZZZZ_SL250_.jpg',
          '/products/' + asin + '.svg'
        ];

        var currentIdx = urls.indexOf(this.src);
        var nextIdx = currentIdx + 1;

        if (nextIdx < urls.length) {
          this.onerror = function() {
            // Try next URL
            var next = urls.indexOf(this.src) + 1;
            if (next < urls.length) {
              this.src = urls[next];
            }
          };
          this.src = urls[nextIdx >= 0 ? nextIdx : 0];
        }
      };

      // Also check if image loaded but is tiny (Amazon sometimes returns 1x1 pixel)
      if (img.complete && img.naturalWidth < 10) {
        img.src = '/products/' + asin + '.svg';
      }
    });
  }

  // Run after initial render
  setTimeout(fixBrokenImages, 500);

  // Also run after any filter change (new products render)
  var originalRenderKit = renderKit;
  renderKit = function(key) {
    originalRenderKit(key);
    setTimeout(fixBrokenImages, 300);
  };
})();
</script>
