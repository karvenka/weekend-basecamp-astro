        },
        '/blogs/low-effort-weekends/the-lazy-sunday-brunch-kit': {
          title: 'The Lazy Sunday Brunch Kit',
          teaser: 'Waffles, French press coffee, vinyl, and the radical act of putting your phone down.'
        },
        '/blogs/low-effort-weekends/weekend-camping-for-couples-who-dont-camp': {
          title: 'Weekend Camping for Couples Who Don\'t Camp',
          teaser: 'You don\'t need to be outdoorsy. You just need to know what to skip and what to bring.'
        },
        '/blogs/low-effort-weekends/the-unplugged-weekend-challenge': {
          title: 'The Unplugged Weekend Challenge',
          teaser: '48 hours without screens. What actually happens is more interesting than that.'
        },
        '/blogs/low-effort-weekends/neighborhood-block-party-playbook': {
          title: 'The Neighborhood Block Party Playbook',
