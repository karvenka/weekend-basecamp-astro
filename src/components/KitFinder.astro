    if (planEl && kit.budget) {
      var roleIcons = {
        'The Fire': '🔥', 'The Game': '🎲', 'The Soundtrack': '🎵', 'The Memory Maker': '📸',
        'The Main Game': '🏆', 'The Backup Game': '🎯', 'The Night Game': '🌙',
        'The Yard Game': '🏸', 'The Party Game': '🎉', 'The Atmosphere': '✨',
        'The Conversation': '💬', 'The Journal': '📖', 'The Soundtrack ': '🎵',
        'The Connection Game': '🤝', 'The Ritual': '🕯️'
      };
      var roleSteps = {
