        'The Backup Game': { time: 'When energy shifts', desc: 'Switch gears. Different pace, different vibe, same crew.' },
        'The Soundtrack': { time: 'The whole time', desc: 'Turn it on early and leave it. Background music makes everything feel intentional.' },
        'The Night Game': { time: 'After sunset', desc: 'The LED glow changes everything. This is when the night levels up.' },
        'The Memory Maker': { time: 'Before it ends', desc: 'Capture it. No filters, no editing. Just the moment.' },
        'The Conversation': { time: 'When it feels right', desc: 'Pull a card. Ask the question. Let the silence do its work.' },
        'The Atmosphere': { time: 'Set up first', desc: 'String them up before anyone arrives. The wow factor is instant.' },
        'The Yard Game': { time: 'Get moving', desc: 'Set it up in the yard. Let people discover it.' },
        'The Party Game': { time: 'Get loud', desc: 'Split into teams. The trash talk starts immediately.' }
