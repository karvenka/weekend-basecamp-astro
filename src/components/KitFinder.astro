      var steps = kit.budget.map(function(p) {
        var icon = roleIcons[p.role] || '📦';
        var step = roleSteps[p.role] || { time: 'Next up', desc: p.why };
        return '<div class="wbs-plan-step">' +
          '<div class="wbs-plan-step-icon">' + icon + '</div>' +
          '<div class="wbs-plan-step-text">' +
            '<div class="wbs-plan-step-time">' + escHtml(step.time) + '</div>' +
            '<div class="wbs-plan-step-desc"><strong>' + escHtml(p.role) + ':</strong> ' + escHtml(step.desc) + '</div>' +
