        },
        '/blogs/low-effort-weekends/trail-running-for-total-beginners': {
          title: 'Trail Running for Total Beginners',
          teaser: 'Why trails are actually easier on your body than roads, and the gear that matters vs. the gear that doesn\'t.'
        },
        '/blogs/low-effort-weekends/the-stargazing-night-guide': {
          title: 'The Stargazing Night Guide',
          teaser: 'What you can actually see in the night sky, how to see it, and how to turn a clear night into something you\'ll remember.'
