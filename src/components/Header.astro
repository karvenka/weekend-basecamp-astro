---
---
<div class="wbc-announcement-bar">✨ Curated by real families, for real weekends</div>
<header id="wbc-header">
  <div class="wbc-header-top">
    <a href="/" class="wbc-logo" aria-label="Weekend Basecamp home">
      <img src="/logo.png" alt="" class="wbc-logo-img" />
      <span class="wbc-logo-text">W E E K E N D &nbsp; B A S E C A M P</span>
    </a>
    <button class="wbc-search-btn" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
  </div>
  <nav class="wbc-nav">
    <a href="/blogs/low-effort-weekends" class="wbc-nav-link">Guides</a>
    <a href="/pages/our-story" class="wbc-nav-link">Our Story</a>
    <a href="/pages/purchasing-faq" class="wbc-nav-link">FAQ</a>
  </nav>
</header>

<style>
  .wbc-announcement-bar {
    background: #CC5500;
    color: #fff;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 16px;
    letter-spacing: 0.02em;
  }
  #wbc-header {
    background: #1a1a1a;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    padding: 0 24px;
  }
  .wbc-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
  }
  .wbc-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .wbc-logo-img {
    height: 32px;
    width: 32px;
    border-radius: 50%;
    object-fit: cover;
  }
  .wbc-logo-text {
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: #f5f0e8;
    text-transform: uppercase;
    font-family: inherit;
  }
  .wbc-search-btn {
    background: none;
    border: none;
    color: #d4c8b8;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .wbc-search-btn:hover { color: #fff; }
  .wbc-nav {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 0 8px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .wbc-nav-link {
    color: #a89880;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    transition: color 0.15s;
    letter-spacing: 0.02em;
  }
  .wbc-nav-link:hover { color: #fff; }
  @media (max-width: 480px) {
    #wbc-header { padding: 0 14px; }
    .wbc-logo-text { font-size: 0.72rem; letter-spacing: 0.15em; }
    .wbc-nav { gap: 14px; }
    .wbc-nav-link { font-size: 0.72rem; }
    .wbc-logo-img { height: 28px; width: 28px; }
  }
</style>
