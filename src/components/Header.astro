---
---
<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-logo" aria-label="Weekend Basecamp home">
      <img src="/logo.webp" alt="" class="site-logo__img" width="32" height="32" />
      <span class="site-logo__text">Weekend Basecamp</span>
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="/destinations" class="site-nav__link">Destinations</a>
      <a href="/guides" class="site-nav__link">Guides</a>
      <a href="/seasonal" class="site-nav__link">Seasonal</a>
      <a href="/our-story" class="site-nav__link">About</a>
    </nav>
    <button class="hamburger-btn" aria-label="Open menu" aria-expanded="false" id="hamburger-toggle">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile nav drawer -->
<div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>
<nav class="mobile-nav-drawer" id="mobile-nav-drawer" aria-label="Mobile navigation">
  <div class="mobile-nav-drawer__header">
    <span class="site-logo__text" style="font-size:0.9rem;">Weekend Basecamp</span>
    <button class="mobile-nav-drawer__close" aria-label="Close menu" id="mobile-nav-close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="mobile-nav-drawer__links">
    <span class="mobile-nav-drawer__section-label">Plan Your Weekend</span>
    <a href="/for/couples" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">💑 Couples</a>
    <a href="/for/family-with-little-ones" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">👶 Little Ones</a>
    <a href="/for/family-with-teens" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">🧑‍🤝‍🧑 With Teens</a>
    <a href="/for/friends" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">🍻 Friends</a>
    <a href="/for/girls-weekend" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">👩‍👩‍👧 Girls' Weekend</a>
    <a href="/for/active-seniors" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">🌿 Active Seniors</a>
    <a href="/for/solo" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">🎒 Solo</a>

    <div class="mobile-nav-drawer__divider"></div>
    <span class="mobile-nav-drawer__section-label">Destinations</span>
    <a href="/leavenworth" class="mobile-nav-drawer__link mobile-nav-drawer__link--sub">🏔️ Leavenworth, WA</a>

    <div class="mobile-nav-drawer__divider"></div>
    <a href="/guides" class="mobile-nav-drawer__link">📋 All Guides</a>
    <a href="/seasonal" class="mobile-nav-drawer__link">🌸 Seasonal</a>
    <a href="/our-story" class="mobile-nav-drawer__link">👋 About Us</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('hamburger-toggle');
  const overlay = document.getElementById('mobile-nav-overlay');
  const drawer = document.getElementById('mobile-nav-drawer');
  const closeBtn = document.getElementById('mobile-nav-close');

  function openNav() {
    overlay?.classList.add('open');
    drawer?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeNav() {
    overlay?.classList.remove('open');
    drawer?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openNav);
  overlay?.addEventListener('click', closeNav);
  closeBtn?.addEventListener('click', closeNav);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });
</script>
