---
interface Props {
  articles: any[];
}
const { articles } = Astro.props;
---
{articles.length > 0 && (
  <div class="related-guides">
    <h3 class="related-guides__heading">You might also like</h3>
    <div class="related-guides__grid">
      {articles.map(article => (
        <a href={`/guides/${article.slug}`} class="guide-card">
          <div class="guide-card__thumb" style={`background:${article.data.thumbnailBg || 'linear-gradient(135deg,#CC5500,#ff8c42)'};`}>
            <span style="font-size:2rem;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.2));">{article.data.thumbnail || '📖'}</span>
          </div>
          <div class="guide-card__body">
            {article.data.category && (
              <span class="guide-card__cat">{article.data.category}</span>
            )}
            <h4 class="guide-card__title">{article.data.title}</h4>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
