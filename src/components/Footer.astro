---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__brand">Weekend Basecamp &copy; {year}</p>

    <div class="site-footer__columns">
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Explore</h4>
        <nav class="site-footer__col-links">
          <a href="/destinations">Destinations</a>
          <a href="/guides">Guides</a>
          <a href="/seasonal">Seasonal</a>
          <a href="/our-story">About</a>
        </nav>
      </div>
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Categories</h4>
        <nav class="site-footer__col-links">
          <a href="/guides/couples">Couples</a>
          <a href="/guides/family">Family</a>
          <a href="/guides/friends">Friends</a>
          <a href="/guides/outdoor">Outdoor</a>
        </nav>
      </div>
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Connect</h4>
        <nav class="site-footer__col-links">
          <a href="https://www.pinterest.com/weekendbasecamp" target="_blank" rel="noopener noreferrer">Pinterest</a>
          <a href="https://www.instagram.com/weekendbasecamp" target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href="/#newsletter">Newsletter</a>
        </nav>
      </div>
    </div>

    <p class="site-footer__disclosure">
      Weekend Basecamp is reader-supported. When you buy through links on our site, we may earn a commission at no extra cost to you.
    </p>
    <nav class="site-footer__legal">
      <a href="/pages/privacy">Privacy</a>
    </nav>
  </div>
</footer>
